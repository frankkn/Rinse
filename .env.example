# Firebase web config — publishable values, NOT secrets (safe in client code).
# Copy this file to `.env.local` and fill in the values from:
#   Firebase Console → Project settings (gear) → General
#   → Your apps → Web app → SDK setup and configuration → Config
#
# Leaving these blank is fine: the game runs fully without login,
# and the "登入以同步" button simply won't appear.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
